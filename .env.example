# Asterisk/FreePBX Configuration
ASTERISK_HOST=192.168.1.100
ASTERISK_PORT=8088
ASTERISK_USERNAME=companion
ASTERISK_PASSWORD=your_password_here
ASTERISK_APP_NAME=ai-companion

# AI Configuration
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Speech-to-Text Configuration
# Deepgram (recommended for real-time STT)
DEEPGRAM_API_KEY=your_deepgram_key_here

# Text-to-Speech Configuration
# Choose provider: 'openai' or 'google'
TTS_PROVIDER=openai

# OpenAI TTS (Recommended - High quality, natural voices)
# Voices: alloy, echo, fable, onyx, nova (default), shimmer
OPENAI_API_KEY=sk-proj-your-openai-key-here
TTS_VOICE_NAME=nova

# Google Cloud TTS (Alternative)
# Only needed if TTS_PROVIDER=google
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# Google voices: en-US-Neural2-J, en-US-Neural2-F, etc.
# TTS_VOICE_NAME=en-US-Neural2-J
TTS_LANGUAGE_CODE=en-US

# Agent Configuration
AGENT_NAME=Companion
AGENT_PERSONALITY=friendly and caring
CALL_TIMEOUT_SECONDS=300
MAX_SILENCE_DURATION=10

# Logging
LOG_LEVEL=info
LOG_FILE=/var/log/ai-companion/companion.log

# Server Configuration
HTTP_PORT=3000

# Webhook Configuration
# Optional: URL to send call analysis and transcripts after each call
# Example: Make.com webhook for call analytics
WEBHOOK_URL=
