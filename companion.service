[Unit]
Description=AI Companion Service - Low Latency Real-time Communication
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/home/user/companion
ExecStart=/usr/bin/npm start
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=companion

# Environment
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target
